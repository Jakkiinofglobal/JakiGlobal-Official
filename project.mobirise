              }
            },
            "@media (min-width: 992px)": {
              ".card-box": {
                "padding-left": "2rem",
                "padding-right": "4rem"
              }
            },
            ".mbr-text, .social-row": {
              "color": "#2299aa"
            },
            ".card-subtitle": {
              "color": "#2299aa"
            },
            ".card-title": {
              "color": "#05386b"
            }
